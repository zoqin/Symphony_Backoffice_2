{% extends 'base.html.twig' %}

{% block title %}New Product{% endblock %}

{% form_theme form 'tailwind_2_layout.html.twig' %}

{% block body %}
    <div class="mb-8">
        <p class="text-sm font-medium text-gray-500">
            Étape {{ form.vars.cursor.stepIndex + 1 }} sur {{ form.vars.cursor.totalSteps }}
        </p>
        <div class="w-full bg-gray-200 rounded-full h-2.5 mt-2">
            {% set percentage = ((form.vars.cursor.stepIndex + 1) / form.vars.cursor.totalSteps) * 100 %}
            <div class="bg-blue-600 h-2.5 rounded-full" style="width: {{ percentage }}%"></div>
        </div>
    </div>

    {{ form_start(form, {attr: {'data-turbo': 'false'}}) }}
    {{ form_widget(form[form.vars.cursor.currentStep]) }}

    <div class="mt-6 flex justify-between">
        <div class="flex gap-2">
            <a href="{{ path('app_product_formflow_reset') }}" class="px-4 py-2 bg-red-500 text-white rounded">
                Annuler
            </a>
            {% if form.navigator.back is defined %}
                {{ form_widget(form.navigator.back, {
                    attr: {class: 'px-4 py-2 bg-gray-500 text-white rounded'}
                }) }}
            {% endif %}
        </div>

        <div class="flex gap-2">
            {% if form.navigator.next is defined %}
                {{ form_widget(form.navigator.next, {
                    attr: {class: 'px-4 py-2 bg-blue-600 text-white rounded'}
                }) }}
            {% endif %}
            {% if form.navigator.finish is defined %}
                {{ form_widget(form.navigator.finish, {
                    attr: {class: 'px-4 py-2 bg-blue-600 text-white rounded'}
                }) }}
            {% endif %}
        </div>
    </div>
    {{ form_end(form) }}
{% endblock %}
